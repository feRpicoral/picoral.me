{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/og/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/github", "destination": "https://github.com/feRpicoral", "permanent": false },
    {
      "source": "/linkedin",
      "destination": "https://www.linkedin.com/in/picoral",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "relay.picoral.me" }],
      "destination": "https://picoral.me/projects/relay",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "sonar.picoral.me" }],
      "destination": "https://picoral.me/projects/sonar",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cite.picoral.me" }],
      "destination": "https://picoral.me/projects/cite",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "recurra.picoral.me" }],
      "destination": "https://picoral.me/projects/recurra",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "indraft.picoral.me" }],
      "destination": "https://picoral.me/projects/indraft",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "forge.picoral.me" }],
      "destination": "https://picoral.me/projects/forge",
      "permanent": false
    }
  ]
}
