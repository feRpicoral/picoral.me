PUBLIC_SITE_URL=https://picoral.me

# OpenRouter API key. OpenRouter is the translation model provider. Needed only to
# run `pnpm translate` locally (which calls the API); CI and Vercel run
# `pnpm translate:check`, which makes no API calls and needs no key.
OPENROUTER_API_KEY=

# Optional local override for the translation model, as an OpenRouter slug
# (see openrouter.ai/models), e.g. anthropic/claude-sonnet-4.6. The committed
# default lives in scripts/translate/config.mjs (TRANSLATOR_MODEL); this var only
# overrides it for your local `pnpm translate` runs. To change the model
# permanently, edit that default instead and re-run `pnpm translate`.
# TRANSLATE_MODEL=
