PUBLIC_SITE_URL=https://picoral.me

# Vercel AI Gateway key — the translator routes through the gateway, which charges
# provider list price with zero markup (also zero with BYOK). Needed only to run
# `pnpm translate` locally (it calls the API); CI and Vercel run `pnpm translate:check`,
# which makes no API call and needs no key. To bill your own provider keys at zero
# markup, configure BYOK in the Vercel dashboard (AI Gateway → Authentication).
AI_GATEWAY_API_KEY=

# Optional local override for the translation model, as a gateway slug `creator/model`
# (see vercel.com/ai-gateway/models), e.g. anthropic/claude-sonnet-4.6,
# google/gemini-2.5-flash-lite, openai/gpt-5.5. Overrides TRANSLATOR_MODEL for this run
# only; to change the default permanently, edit it in scripts/translate/config.mjs.
# TRANSLATE_MODEL=

# Optional: cap output tokens per request (default 8192). Lower it for tight provider
# tiers — Anthropic sizes its per-minute output limit off this, so on Sonnet tier 1
# (8k/min) set 4096 or less. Applies to `pnpm translate`.
# TRANSLATE_MAX_OUTPUT_TOKENS=
