PUBLIC_SITE_URL=https://picoral.me

# Translation provider API keys. Needed only to run `pnpm translate` locally (it
# calls the API); CI and Vercel run `pnpm translate:check`, which makes no API call
# and needs none of these. Set only the provider(s) you use — the default model
# (TRANSLATOR_MODEL in scripts/translate/config.mjs) is anthropic/*.
ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=   # for google/* models
# OPENAI_API_KEY=                 # for openai/* models
# OPENROUTER_API_KEY=             # for openrouter/* fallback (any model by slug)

# Optional local override for the translation model, as `<provider>/<model>`, e.g.
# anthropic/claude-sonnet-4-6, google/gemini-2.5-flash-lite, openai/gpt-4o-mini, or
# openrouter/<any-openrouter-slug>. Overrides TRANSLATOR_MODEL for this run only; to
# change the default permanently, edit it in scripts/translate/config.mjs.
# TRANSLATE_MODEL=
