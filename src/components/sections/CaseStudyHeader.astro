---
import Pill from '~/components/ui/Pill.astro';
import { type Locale } from '~/config/site.ts';
import type { UiKey } from '~/i18n/ui.ts';
import { useTranslations } from '~/i18n/utils.ts';
import { formatPeriodRange } from '~/lib/format.ts';

interface Props {
  title: string;
  tagline: string;
  status: 'live' | 'beta' | 'in-development' | 'archived';
  role: string;
  period: { start: string; end?: string };
  stack: string[];
  links?: { live?: string; repo?: string; demo?: string };
  locale: Locale;
}
const { title, tagline, status, role, period, stack, links, locale } = Astro.props;
const t = useTranslations(locale);
const statusVariant = status === 'live' ? 'success' : status === 'beta' ? 'accent' : 'muted';
const periodLabel = formatPeriodRange(period.start, period.end, locale, t('experience.present'));
const statusLabel = t(`projects.status.${status}` as UiKey);
---

<header class="case-header">
  <div class="title-row">
    <h1 class="display-serif title">{title}</h1>
    <Pill variant={statusVariant}>{statusLabel}</Pill>
  </div>
  <p class="tagline text-pretty">{tagline}</p>

  <dl class="meta">
    <div>
      <dt>{t('projects.role')}</dt>
      <dd>{role}</dd>
    </div>
    <div>
      <dt>{t('projects.period')}</dt>
      <dd>{periodLabel}</dd>
    </div>
    <div>
      <dt>{t('projects.stack')}</dt>
      <dd>
        <ul class="stack">
          {stack.map((s) => <li>{s}</li>)}
        </ul>
      </dd>
    </div>
    {links && (links.live || links.repo || links.demo) && (
      <div>
        <dt>{t('projects.links')}</dt>
        <dd>
          <ul class="links">
            {links.live && (
              <li>
                <a href={links.live} target="_blank" rel="noopener noreferrer">
                  {t('projects.viewLive')}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 7h10v10" />
                    <path d="M7 17 17 7" />
                  </svg>
                </a>
              </li>
            )}
            {links.repo && (
              <li>
                <a href={links.repo} target="_blank" rel="noopener noreferrer">
                  {t('projects.viewRepo')}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 7h10v10" />
                    <path d="M7 17 17 7" />
                  </svg>
                </a>
              </li>
            )}
            {links.demo && (
              <li>
                <a href={links.demo} target="_blank" rel="noopener noreferrer">
                  {t('projects.viewDemo')}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 7h10v10" />
                    <path d="M7 17 17 7" />
                  </svg>
                </a>
              </li>
            )}
          </ul>
        </dd>
      </div>
    )}
  </dl>
</header>

<style>
  .case-header {
    margin-bottom: 3.5rem;
  }
  .title-row {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    font-style: italic;
    font-weight: 400;
    margin: 0;
  }
  .tagline {
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--color-fg-muted);
    margin: 0 0 2.5rem;
    max-width: 38rem;
  }
  .meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-subtle);
    margin: 0;
  }
  @media (min-width: 640px) {
    .meta {
      grid-template-columns: max-content 1fr;
      column-gap: 2rem;
      row-gap: 1rem;
      padding: 1.75rem 2rem;
    }
    .meta > div {
      display: contents;
    }
  }
  .meta dt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fg-subtle);
    margin: 0;
  }
  .meta dd {
    margin: 0;
    color: var(--color-fg);
    font-size: 0.9375rem;
  }
  .stack,
  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .stack li {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-fg-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }
  .links li a {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-fg);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: all 150ms ease;
  }
  .links li a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
