---
import Pill from '~/components/ui/Pill.astro';
import { type Locale } from '~/config/site.ts';
import { useTranslations } from '~/i18n/utils.ts';
import type { UiKey } from '~/i18n/ui.ts';

interface Props {
  /** Optional. When omitted, the card renders as a non-link <article>. */
  href?: string;
  /** Set when href points off-site. */
  external?: boolean;
  title: string;
  tagline: string;
  status: 'live' | 'beta' | 'in-development' | 'archived';
  stack: string[];
  locale: Locale;
}
const { href, external = false, title, tagline, status, stack, locale } = Astro.props;
const t = useTranslations(locale);
const statusVariant = status === 'live' ? 'success' : status === 'beta' ? 'accent' : 'muted';
const statusLabel = t(`projects.status.${status}` as UiKey);
const Tag = href ? 'a' : 'article';
const linkProps = href ? { href, ...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {}) } : {};
---

<Tag class={`card ${href ? 'card--link' : ''}`} {...linkProps}>
  <div class="head">
    <h3 class="title">{title}</h3>
    <Pill variant={statusVariant}>{statusLabel}</Pill>
  </div>
  <p class="tag text-pretty">{tagline}</p>
  <ul class="stack">
    {stack.slice(0, 5).map((tech) => <li>{tech}</li>)}
  </ul>
</Tag>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    color: var(--color-fg);
    text-decoration: none;
    transition: all 200ms ease;
    height: 100%;
    overflow: hidden;
  }
  .card--link:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-strong);
    background: var(--color-bg-subtle);
    box-shadow: var(--shadow-sm);
  }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .title {
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .tag {
    color: var(--color-fg-muted);
    line-height: 1.55;
    font-size: 0.9375rem;
    margin: 0;
    flex: 1;
  }
  .stack {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .stack li {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-fg-subtle);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    line-height: 1.5;
  }
  .card--link:hover .stack li {
    background: var(--color-bg-elevated);
  }
</style>
