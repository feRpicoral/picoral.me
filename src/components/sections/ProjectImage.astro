---
import { Image } from 'astro:assets';

type Size = 'prose' | 'chart' | 'wide' | 'phone';
const ASSET_ALIAS_PREFIX = '@assets/';
const ASSET_ROOT_PREFIX = '/src/assets/';
const IMAGE_SIZES = {
  prose: {
    widths: [320, 640, 960, 1200],
    sizes: '(min-width: 42rem) 42rem, calc(100vw - 2rem)',
  },
  chart: {
    widths: [320, 640, 960, 1200],
    sizes: '(min-width: 38rem) 38rem, calc(100vw - 2rem)',
  },
  wide: {
    widths: [640, 960, 1200, 1600],
    sizes: '(min-width: 56rem) 56rem, calc(100vw - 2.5rem)',
  },
  phone: {
    widths: [240, 360, 480, 720, 960],
    sizes: '(min-width: 27rem) 27rem, calc(100vw - 2rem)',
  },
} satisfies Record<Size, { widths: number[]; sizes: string }>;

interface Props {
  src: string;
  alt: string;
  caption?: string;
  size?: Size;
}

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/projects/**/*.{avif,gif,jpeg,jpg,png,webp}',
  { eager: true },
);

const { src, alt, caption, size = 'prose' } = Astro.props;
const imageKey = src.startsWith(ASSET_ALIAS_PREFIX)
  ? `${ASSET_ROOT_PREFIX}${src.slice(ASSET_ALIAS_PREFIX.length)}`
  : src;
const image = images[imageKey]?.default;
if (!image) throw new Error(`Unknown project image: ${src}`);

const imageSize = IMAGE_SIZES[size];
const widths = imageSize.widths.filter((width) => width <= image.width);
if (!widths.includes(image.width)) widths.push(image.width);
const sizes = imageSize.sizes;
---

<figure class:list={['project-image', `project-image--${size}`]}>
  <Image
    src={image}
    alt={alt}
    widths={widths}
    sizes={sizes}
    format="webp"
    quality={80}
    loading="lazy"
    decoding="async"
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .project-image {
    margin: 2.25rem auto;
  }
  .project-image--prose {
    width: min(100%, 42rem);
  }
  .project-image--chart {
    --project-image-width: min(38rem, calc(100vw - 2rem));
    width: var(--project-image-width);
    margin-left: calc((100% - var(--project-image-width)) / 2);
  }
  .project-image--wide {
    --project-image-width: min(56rem, calc(100vw - 2.5rem));
    width: var(--project-image-width);
    margin-left: calc((100% - var(--project-image-width)) / 2);
  }
  .project-image--phone {
    --project-image-width: min(27rem, calc(100vw - 2rem));
    width: var(--project-image-width);
    margin-left: calc((100% - var(--project-image-width)) / 2);
  }
  .project-image :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  .project-image--phone :global(img) {
    border: none;
    border-radius: 0;
    box-shadow: none;
  }
  figcaption {
    margin-top: 0.75rem;
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-fg-muted);
  }
</style>
