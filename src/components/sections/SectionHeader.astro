---
import Eyebrow from '~/components/ui/Eyebrow.astro';
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, lead, align = 'left' } = Astro.props;
---

<header class={`sec-header sec-header--${align}`}>
  {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
  <h2 class="title">{title}</h2>
  {lead && <p class="lead text-pretty">{lead}</p>}
</header>

<style>
  .sec-header {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 3rem;
    max-width: 42rem;
  }
  .sec-header--center {
    text-align: center;
    margin-inline: auto;
    align-items: center;
  }
  .title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .lead {
    font-size: 1.0625rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }
</style>
