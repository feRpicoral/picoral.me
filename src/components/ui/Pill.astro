---
interface Props {
  variant?: 'default' | 'accent' | 'success' | 'muted';
  class?: string;
}
const { variant = 'default', class: className = '' } = Astro.props;
---

<span class={`pill pill--${variant} ${className}`}>
  <slot />
</span>

<style>
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    line-height: 1.3;
    border: 1px solid var(--color-border);
  }
  .pill--default {
    background: var(--color-bg-subtle);
    color: var(--color-fg-muted);
  }
  .pill--accent {
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    border-color: transparent;
  }
  .pill--success {
    background: oklch(95% 0.05 145);
    color: oklch(38% 0.12 145);
    border-color: transparent;
  }
  [data-theme='dark'] .pill--success {
    background: oklch(25% 0.04 145);
    color: oklch(80% 0.14 145);
  }
  .pill--muted {
    background: transparent;
    color: var(--color-fg-subtle);
  }
</style>
