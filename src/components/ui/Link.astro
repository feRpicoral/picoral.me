---
interface Props {
  href: string;
  external?: boolean;
  class?: string;
  underline?: boolean;
  'aria-current'?: 'page' | 'true';
  'aria-label'?: string;
}
const {
  href,
  external = false,
  class: className = '',
  underline = false,
  'aria-current': ariaCurrent,
  'aria-label': ariaLabel,
} = Astro.props;
const isExternal = external || /^https?:\/\//.test(href);
const externalProps = isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  class={`link ${underline ? 'link--underline' : ''} ${className}`}
  aria-current={ariaCurrent}
  aria-label={ariaLabel}
  {...externalProps}
>
  <slot />
  {isExternal && (
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <path d="M7 7h10v10" />
      <path d="M7 17 17 7" />
    </svg>
  )}
</a>

<style>
  .link {
    color: inherit;
    text-decoration: none;
    transition: color 150ms ease;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .link:hover {
    color: var(--color-accent);
  }
  .link--underline {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    text-decoration-color: var(--color-border-strong);
  }
  .link--underline:hover {
    text-decoration-color: var(--color-accent);
  }
</style>
