---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<p class={`eyebrow ${className}`}>
  <slot />
</p>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-subtle);
    margin: 0;
  }
</style>
