---
interface Props {
  /** prose: 42rem, content: 64rem, wide: 80rem (default: content) */
  size?: 'prose' | 'content' | 'wide';
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}
const { size = 'content', as: Tag = 'div', class: className = '' } = Astro.props;
const maxWidth =
  size === 'prose'
    ? 'var(--container-prose)'
    : size === 'wide'
      ? 'var(--container-wide)'
      : 'var(--container-content)';
---

<Tag class={`container ${className}`} style={`--container-max:${maxWidth}`}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: 1.25rem;
  }
  @media (min-width: 640px) {
    .container {
      padding-inline: 2rem;
    }
  }
</style>
