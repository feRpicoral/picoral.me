---
import Container from '~/components/ui/Container.astro';
import { SITE } from '~/config/site.ts';
import { getLocaleFromUrl, useTranslations } from '~/i18n/utils.ts';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <Container size="wide">
    <div class="cols">
      <div>
        <p class="copy">{t('footer.copyright', { year })}</p>
        <p class="built">
          {t('footer.builtWith')} <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.
          <a
            href="https://github.com/feRpicoral/picoral.me"
            target="_blank"
            rel="noopener noreferrer"
            class="src"
          >
            {t('footer.sourceCode')} →
          </a>
        </p>
      </div>
      <ul class="socials" aria-label="Social links">
        <li>
          <a href={SITE.socials.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
          </a>
        </li>
        <li>
          <a href={SITE.socials.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </li>
        <li>
          <a href="#" data-email-user={SITE.emailUser} data-email-domain={SITE.emailDomain} aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding-block: 3rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    font-size: 0.875rem;
  }
  .cols {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: space-between;
    align-items: flex-start;
  }
  @media (min-width: 640px) {
    .cols {
      flex-direction: row;
      align-items: center;
    }
  }
  .copy {
    margin: 0;
    color: var(--color-fg);
    font-weight: 500;
  }
  .built {
    margin: 0.375rem 0 0;
    font-size: 0.8125rem;
  }
  .built a {
    color: var(--color-fg-muted);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-color: var(--color-border-strong);
  }
  .built a:hover {
    color: var(--color-accent);
  }
  .src {
    margin-left: 0.5rem;
  }
  .socials {
    list-style: none;
    display: flex;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    color: var(--color-fg-muted);
    transition: all 150ms ease;
  }
  .socials a:hover {
    color: var(--color-fg);
    background: var(--color-bg-subtle);
  }
</style>
