---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Seo from '~/components/seo/Seo.astro';
import { SITE } from '~/config/site.ts';
import { bcp47, getLocaleFromUrl, useTranslations } from '~/i18n/utils.ts';
import '~/styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Canonical path WITHOUT locale prefix, e.g. '/about'. Used for hreflang siblings. */
  canonicalPath: string;
  /** OG image URL relative to site (e.g. '/og/home.png'). */
  ogImage?: string;
  /** Optional schema.org JSON-LD payloads to inject into <head>. */
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, canonicalPath, ogImage, jsonLd, noindex } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lang = bcp47(locale);
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fafaf9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1b26" media="(prefers-color-scheme: dark)" />

    {/* Pre-paint theme bootstrap to avoid FOUC */}
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (_) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>

    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      jsonLd={jsonLd}
      noindex={noindex}
    />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">{t('nav.skip')}</a>
    <slot />

    {/*
      Email anti-spam: any <a data-email-user="…" data-email-domain="…"> is wired
      up to a real mailto: only after JS runs. The literal address never appears
      in server-rendered HTML. Re-runs on Astro view transitions.
    */}
    <script is:inline>
      (() => {
        const wireEmails = () => {
          const links = document.querySelectorAll('a[data-email-user][data-email-domain]');
          links.forEach((el) => {
            if (el.dataset.emailReady === '1') return;
            const user = el.dataset.emailUser;
            const domain = el.dataset.emailDomain;
            if (!user || !domain) return;
            const email = user + '@' + domain;
            el.setAttribute('href', 'mailto:' + email);
            el.querySelectorAll('[data-email-text]').forEach((t) => {
              t.textContent = email;
            });
            el.dataset.emailReady = '1';
          });
        };
        wireEmails();
        document.addEventListener('astro:page-load', wireEmails);
      })();
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
