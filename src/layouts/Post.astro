---
import Container from '~/components/ui/Container.astro';
import Section from '~/components/ui/Section.astro';
import Page from './Page.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>[];
  publishedAt?: Date;
  updatedAt?: Date;
}
const { title, description, canonicalPath, ogImage, jsonLd, publishedAt, updatedAt } = Astro.props;
---

<Page
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <Section spacing="md">
    <Container size="prose">
      <article>
        <header class="post-header">
          <h1>{title}</h1>
          <p class="lead">{description}</p>
          {publishedAt && (
            <p class="meta">
              <time datetime={publishedAt.toISOString()}>
                {publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              {updatedAt && updatedAt.getTime() !== publishedAt.getTime() && (
                <>
                  · updated <time datetime={updatedAt.toISOString()}>
                    {updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </>
              )}
            </p>
          )}
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
    </Container>
  </Section>
</Page>

<style>
  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  .post-header h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .post-header .lead {
    font-size: 1.125rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
    text-wrap: pretty;
  }
  .post-header .meta {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
