---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Breadcrumbs from '~/components/nav/Breadcrumbs.astro';
import CaseStudyHeader from '~/components/sections/CaseStudyHeader.astro';
import FAQ from '~/components/sections/FAQ.astro';
import SectionHeader from '~/components/sections/SectionHeader.astro';
import Container from '~/components/ui/Container.astro';
import Section from '~/components/ui/Section.astro';
import { isEnabled } from '~/config/sections.ts';
import { SITE } from '~/config/site.ts';
import projectDates from '~/data/project-dates.json';
import { getLocaleFromUrl, localizePath, useTranslations } from '~/i18n/utils.ts';
import Page from '~/layouts/Page.astro';
import { getCanonicalSlug, getLocalizedEntry } from '~/lib/content.ts';
import { formatDateTimeTz } from '~/lib/format.ts';
import { breadcrumbSchema, faqPageSchema, softwareApplicationSchema } from '~/lib/schema.ts';

export async function getStaticPaths() {
  if (!isEnabled('projectCaseStudies')) return [];
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  const seen = new Set<string>();
  const result: { params: { slug: string }; props: { entry: CollectionEntry<'projects'> } }[] = [];
  for (const entry of projects) {
    const slug = getCanonicalSlug(entry.id);
    const isEn = entry.id.startsWith('en/');
    if (!isEn) continue;
    if (!entry.data.hasCaseStudy) continue;
    if (seen.has(slug)) continue;
    seen.add(slug);
    result.push({ params: { slug }, props: { entry } });
  }
  return result;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404', 404);

const entry = await getLocalizedEntry('projects', locale, slug);
if (!entry) return Astro.redirect('/404', 404);
const { Content } = await render(entry);
const { data } = entry;

const dates = projectDates[slug as keyof typeof projectDates] ?? null;
const publishedLabel = dates
  ? `${t('projects.published')} ${formatDateTimeTz(dates.published, locale)}`
  : null;
const updatedLabel =
  dates && dates.updated !== dates.published
    ? `${t('projects.updated')} ${formatDateTimeTz(dates.updated, locale)}`
    : null;

const jsonLd: Record<string, unknown>[] = [
  breadcrumbSchema([
    { name: 'Home', url: SITE.url },
    { name: t('projects.title'), url: `${SITE.url}/projects` },
    { name: data.title, url: `${SITE.url}/projects/${slug}` },
  ]),
  softwareApplicationSchema({
    name: data.title,
    description: data.seo.description,
    url: data.links?.live,
    datePublished: dates?.published,
    dateModified: dates?.updated,
  }),
];
if (data.faq && data.faq.length > 0) {
  jsonLd.push(faqPageSchema(data.faq));
}
---

<Page
  title={data.title}
  description={data.seo.description}
  canonicalPath={`/projects/${slug}`}
  ogImage={`/og/projects/${slug}.png`}
  jsonLd={jsonLd}
>
  <Section spacing="md">
    <Container size="prose">
      <Breadcrumbs
        items={[
          { label: t('nav.projects'), href: localizePath('/projects', locale) },
          { label: data.title },
        ]}
      />
      <CaseStudyHeader
        title={data.title}
        tagline={data.tagline}
        status={data.status}
        role={data.role}
        period={data.period}
        stack={data.stack}
        links={data.links}
        locale={locale}
      />
      <div class="prose">
        <Content />
      </div>
      {data.faq && data.faq.length > 0 && (
        <div class="faq-wrap">
          <SectionHeader title={t('projects.faq')} />
          <FAQ items={data.faq} />
        </div>
      )}
      <footer class="case-foot">
        {publishedLabel && (
          <p class="dates">{publishedLabel}{updatedLabel && ` · ${updatedLabel}`}</p>
        )}
        <p class="back">
          <a href={localizePath('/projects', locale)}>{t('projects.backToList')}</a>
        </p>
      </footer>
    </Container>
  </Section>
</Page>

<style>
  .faq-wrap {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }
  .case-foot {
    margin-top: 3.5rem;
  }
  .dates {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-fg-subtle);
  }
  .back {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
  .back a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .back a:hover {
    color: var(--color-accent);
  }
</style>
