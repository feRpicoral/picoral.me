---
import FAQ from '~/components/sections/FAQ.astro';
import Hero from '~/components/sections/Hero.astro';
import ProjectCard from '~/components/sections/ProjectCard.astro';
import SectionHeader from '~/components/sections/SectionHeader.astro';
import Container from '~/components/ui/Container.astro';
import Section from '~/components/ui/Section.astro';
import { SITE } from '~/config/site.ts';
import { getHomeFaq } from '~/data/home-faq.ts';
import { getLocaleFromUrl, localizePath, useTranslations } from '~/i18n/utils.ts';
import Page from '~/layouts/Page.astro';
import { getCanonicalSlug, getLocalizedCollection } from '~/lib/content.ts';
import { faqPageSchema, personSchema, websiteSchema } from '~/lib/schema.ts';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const allProjects = await getLocalizedCollection('projects', locale);
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const faqItems = getHomeFaq(locale);

const jsonLd = [personSchema(), websiteSchema(locale), faqPageSchema(faqItems)];
---

<Page
  title={SITE.name}
  description={SITE.description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <Hero
    eyebrow={t('home.hero.eyebrow')}
    title={t('home.hero.title')}
    lead={t('home.hero.lead')}
    ctaPrimary={{ label: t('home.hero.ctaProjects'), href: localizePath('/projects', locale) }}
    ctaSecondary={{ label: t('home.hero.ctaAbout'), href: localizePath('/about', locale) }}
  />

  {featured.length > 0 && (
    <Section spacing="md" id="featured">
      <Container size="wide">
        <SectionHeader
          eyebrow={t('projects.featured')}
          title={t('home.projects.title')}
          lead={t('home.projects.lead')}
        />
        <div class="grid">
          {featured.map((project) => {
            const slug = getCanonicalSlug(project.id);
            return (
              <ProjectCard
                href={localizePath(`/projects/${slug}`, locale)}
                title={project.data.title}
                tagline={project.data.tagline}
                status={project.data.status}
                stack={project.data.stack}
                locale={locale}
              />
            );
          })}
        </div>
        <div class="all">
          <a href={localizePath('/projects', locale)} class="all-link">
            {t('home.projects.allCta')}
          </a>
        </div>
      </Container>
    </Section>
  )}

  <Section spacing="md" id="faq">
    <Container size="content">
      <SectionHeader title={t('home.faq.title')} />
      <FAQ items={faqItems} />
    </Container>
  </Section>
</Page>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .all {
    margin-top: 2.5rem;
    text-align: center;
  }
  .all-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    transition: all 150ms ease;
  }
  .all-link:hover {
    color: var(--color-accent);
  }
</style>
