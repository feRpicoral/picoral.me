---
import FAQ from '~/components/sections/FAQ.astro';
import Hero from '~/components/sections/Hero.astro';
import ProjectCard from '~/components/sections/ProjectCard.astro';
import SectionHeader from '~/components/sections/SectionHeader.astro';
import Container from '~/components/ui/Container.astro';
import Section from '~/components/ui/Section.astro';
import { SITE } from '~/config/site.ts';
import { getLocaleFromUrl, localizePath, useTranslations } from '~/i18n/utils.ts';
import Page from '~/layouts/Page.astro';
import { getLocalizedCollection } from '~/lib/content.ts';
import { faqPageSchema, personSchema, websiteSchema } from '~/lib/schema.ts';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const allProjects = await getLocalizedCollection('projects', locale);
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const faqItems = [
  {
    q:
      locale === 'pt'
        ? 'Quem é Fernando Picoral?'
        : locale === 'es'
          ? '¿Quién es Fernando Picoral?'
          : 'Who is Fernando Picoral?',
    a:
      locale === 'pt'
        ? 'Fernando Picoral é um engenheiro de software brasileiro baseado em Nova York. Acabou de se formar em Ciência da Computação pela University of Colorado Boulder (maio de 2026) e entra no Google em tempo integral como Software Engineer em setembro de 2026, depois de três estágios na empresa em Kirkland, Sunnyvale e Nova York.'
        : locale === 'es'
          ? 'Fernando Picoral es un ingeniero de software brasileño basado en Nueva York. Acaba de graduarse en Ciencias de la Computación de la University of Colorado Boulder (mayo de 2026) y se une a Google a tiempo completo como Software Engineer en septiembre de 2026, tras tres pasantías con la empresa en Kirkland, Sunnyvale y Nueva York.'
          : 'Fernando Picoral is a Brazilian software engineer based in New York. He just graduated from the University of Colorado Boulder in May 2026 with a degree in Computer Science, and is joining Google full-time as a Software Engineer in September 2026 after three summer internships with the company in Kirkland, Sunnyvale, and NYC.',
  },
  {
    q:
      locale === 'pt'
        ? 'Em que Fernando está trabalhando agora?'
        : locale === 'es'
          ? '¿En qué está trabajando Fernando ahora?'
          : 'What is Fernando working on right now?',
    a:
      locale === 'pt'
        ? 'Alguns projetos pessoais em IA — voz, multi-agente, RAG e cobrança recorrente. Existem apenas como lugares para aprender a próxima coisa. Em setembro de 2026 começa no Google em tempo integral.'
        : locale === 'es'
          ? 'Algunos proyectos personales en IA — voz, multi-agente, RAG y cobros recurrentes. Existen solo como lugares para aprender lo siguiente. En septiembre de 2026 empieza en Google a tiempo completo.'
          : 'A handful of personal projects in AI — voice, multi-agent, RAG, and recurring billing. They exist only as places to learn the next thing. He starts at Google full-time in September 2026.',
  },
  {
    q:
      locale === 'pt'
        ? 'Como entrar em contato com Fernando?'
        : locale === 'es'
          ? '¿Cómo contactar a Fernando?'
          : 'How do I contact Fernando?',
    a:
      locale === 'pt'
        ? 'O caminho mais rápido é por e-mail (veja a página de contato). Também pode encontrá-lo no GitHub (@feRpicoral) e no LinkedIn (/in/picoral).'
        : locale === 'es'
          ? 'La forma más rápida es por correo (ver la página de contacto). También puedes encontrarlo en GitHub (@feRpicoral) y LinkedIn (/in/picoral).'
          : 'The fastest way is email (see the contact page). You can also find him on GitHub (@feRpicoral) and LinkedIn (/in/picoral).',
    aHtml:
      locale === 'pt'
        ? `O caminho mais rápido é por e-mail (veja a <a href="${localizePath('/contact', locale)}">página de contato</a>). Também pode encontrá-lo no <a href="${SITE.socials.github}" target="_blank" rel="noopener noreferrer">GitHub</a> (@feRpicoral) e no <a href="${SITE.socials.linkedin}" target="_blank" rel="noopener noreferrer">LinkedIn</a> (/in/picoral).`
        : locale === 'es'
          ? `La forma más rápida es por correo (ver la <a href="${localizePath('/contact', locale)}">página de contacto</a>). También puedes encontrarlo en <a href="${SITE.socials.github}" target="_blank" rel="noopener noreferrer">GitHub</a> (@feRpicoral) y <a href="${SITE.socials.linkedin}" target="_blank" rel="noopener noreferrer">LinkedIn</a> (/in/picoral).`
          : `The fastest way is email (see the <a href="${localizePath('/contact', locale)}">contact page</a>). You can also find him on <a href="${SITE.socials.github}" target="_blank" rel="noopener noreferrer">GitHub</a> (@feRpicoral) and <a href="${SITE.socials.linkedin}" target="_blank" rel="noopener noreferrer">LinkedIn</a> (/in/picoral).`,
  },
  {
    q:
      locale === 'pt'
        ? 'Que idiomas Fernando fala?'
        : locale === 'es'
          ? '¿Qué idiomas habla Fernando?'
          : 'What languages does Fernando speak?',
    a:
      locale === 'pt'
        ? 'Português (nativo), inglês (fluente) e espanhol (proficiência de trabalho). Este site está disponível nos três idiomas.'
        : locale === 'es'
          ? 'Portugués (nativo), inglés (fluido) y español (proficiencia de trabajo). Este sitio está disponible en los tres idiomas.'
          : 'Portuguese (native), English (fluent), and Spanish (working proficiency). This site is available in all three.',
  },
];

const jsonLd = [personSchema(), websiteSchema(locale), faqPageSchema(faqItems)];
---

<Page
  title={SITE.name}
  description={SITE.description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <Hero
    eyebrow={t('home.hero.eyebrow')}
    title={t('home.hero.title')}
    lead={t('home.hero.lead')}
    ctaPrimary={{ label: t('home.hero.ctaProjects'), href: localizePath('/projects', locale) }}
    ctaSecondary={{ label: t('home.hero.ctaAbout'), href: localizePath('/about', locale) }}
  />

  {featured.length > 0 && (
    <Section spacing="md" id="featured">
      <Container size="wide">
        <SectionHeader
          eyebrow={t('projects.featured')}
          title={t('home.projects.title')}
          lead={t('home.projects.lead')}
        />
        <div class="grid">
          {featured.map((project) => (
            <ProjectCard
              href={localizePath(`/projects/${project.data.slug}`, locale)}
              title={project.data.title}
              tagline={project.data.tagline}
              status={project.data.status}
              stack={project.data.stack}
              locale={locale}
            />
          ))}
        </div>
        <div class="all">
          <a href={localizePath('/projects', locale)} class="all-link">
            {t('home.projects.allCta')}
          </a>
        </div>
      </Container>
    </Section>
  )}

  <Section spacing="md" id="faq">
    <Container size="content">
      <SectionHeader title={t('home.faq.title')} />
      <FAQ items={faqItems} />
    </Container>
  </Section>
</Page>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .all {
    margin-top: 2.5rem;
    text-align: center;
  }
  .all-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    transition: all 150ms ease;
  }
  .all-link:hover {
    color: var(--color-accent);
  }
</style>
