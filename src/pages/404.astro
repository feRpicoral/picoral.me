---
import Button from '~/components/ui/Button.astro';
import Container from '~/components/ui/Container.astro';
import Section from '~/components/ui/Section.astro';
import { SITE } from '~/config/site.ts';
import { getLocaleFromUrl, useTranslations } from '~/i18n/utils.ts';
import Page from '~/layouts/Page.astro';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<Page
  title={t('page.notFound.title')}
  description={t('page.notFound.body')}
  canonicalPath="/404"
  noindex
>
  <Section spacing="lg">
    <Container size="prose">
      <p class="code">404</p>
      <h1 class="display-serif">{t('page.notFound.title')}</h1>
      <p class="lead text-pretty">{t('page.notFound.body')}</p>
      <Button href={locale === 'en' ? '/' : `/${locale}`} variant="primary">
        {t('page.notFound.cta')}
      </Button>
    </Container>
  </Section>
</Page>

<style>
  .code {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    margin: 0 0 1rem;
    letter-spacing: 0.1em;
  }
  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 1rem;
    line-height: 1.05;
    font-style: italic;
  }
  .lead {
    font-size: 1.125rem;
    color: var(--color-fg-muted);
    margin: 0 0 2rem;
    line-height: 1.6;
  }
</style>
