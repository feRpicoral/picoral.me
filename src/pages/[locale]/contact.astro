---
import { render } from 'astro:content';
import CopyEmail from '~/components/islands/CopyEmail.tsx';
import SocialLinks from '~/components/sections/SocialLinks.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Section from '~/components/ui/Section.astro';
import { type Locale, SITE } from '~/config/site.ts';
import { useTranslations } from '~/i18n/utils.ts';
import Page from '~/layouts/Page.astro';
import { getLocalizedEntry } from '~/lib/content.ts';
import { breadcrumbSchema } from '~/lib/schema.ts';

export function getStaticPaths() {
  return SITE.locales
    .filter((l) => l !== SITE.defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);

const entry = await getLocalizedEntry('pages', locale, 'contact');
if (!entry) return Astro.redirect('/404', 404);
const { Content } = await render(entry);

const jsonLd = [
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/${locale}` },
    { name: t('contact.title'), url: `${SITE.url}/${locale}/contact` },
  ]),
];
---

<Page
  title={t('contact.title')}
  description={t('contact.lead')}
  canonicalPath="/contact"
  jsonLd={jsonLd}
>
  <Section spacing="md">
    <Container size="prose">
      <Eyebrow>{t('contact.title')}</Eyebrow>
      <h1 class="display-serif title">{t('contact.title')}</h1>
      <p class="lead text-pretty">{t('contact.lead')}</p>

      <div class="email-block">
        <p class="email-label">{t('contact.email.label')}</p>
        <div class="email-row">
          <a
            href="#"
            class="email-link"
            data-email-user={SITE.emailUser}
            data-email-domain={SITE.emailDomain}
            aria-label={`${SITE.emailUser} at ${SITE.emailDomain}`}
          >
            <span data-email-text>{SITE.emailUser} [at] {SITE.emailDomain}</span>
          </a>
          <CopyEmail
            client:idle
            user={SITE.emailUser}
            domain={SITE.emailDomain}
            labels={{ copy: t('contact.email.copy'), copied: t('contact.email.copied') }}
          />
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>

      <div class="socials">
        <p class="socials-label">{t('contact.social.title')}</p>
        <SocialLinks />
      </div>
    </Container>
  </Section>
</Page>

<style>
  .title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    margin: 0.75rem 0 1.5rem;
    font-style: italic;
    font-weight: 400;
  }
  .lead {
    font-size: 1.25rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
    margin: 0 0 2.5rem;
  }
  .email-block {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-subtle);
    margin-bottom: 3rem;
  }
  .email-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fg-subtle);
    margin: 0 0 0.5rem;
  }
  .email-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .email-link {
    font-family: var(--font-mono);
    font-size: 1.0625rem;
    color: var(--color-fg);
    text-decoration: none;
    word-break: break-all;
  }
  .email-link:hover {
    color: var(--color-accent);
  }
  .socials {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }
  .socials-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fg-subtle);
    margin: 0 0 1rem;
  }
</style>
